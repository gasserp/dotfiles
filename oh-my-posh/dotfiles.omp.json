{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "╭─",
          "trailing_diamond": "",
          "foreground": "#26C6DA",
          "background": "#1E1E2E",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} "
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#FFFFFF",
          "background": "#3B3B5C",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#FFFFFF",
          "background": "#0077C2",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "folder_separator_icon": "  "
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#193549",
          "background": "#FFFB38",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#FF6F61{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#C792EA{{ end }}",
            "{{ if gt .Ahead 0 }}#82AAFF{{ end }}",
            "{{ if gt .Behind 0 }}#F78C6C{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "powerline",
          "powerline_symbol": "",
          "invert_powerline": true,
          "foreground": "#FFFFFF",
          "background": "#3B3B5C",
          "properties": {
            "threshold": 500,
            "style": "austin"
          },
          "template": " ﮫ {{ .FormattedMs }} "
        },
        {
          "type": "time",
          "style": "diamond",
          "invert_powerline": true,
          "leading_diamond": "",
          "trailing_diamond": "─╮",
          "foreground": "#FFFFFF",
          "background": "#26C6DA",
          "properties": {
            "time_format": "15:04:05"
          },
          "template": " {{ .CurrentDate | date .Format }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#26C6DA",
          "template": "╰─"
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "#A6E22E",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FF5555{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "template": "❯ "
        }
      ]
    }
  ]
}
